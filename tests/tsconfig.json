{
  "extends": "../configs/tsconfig.json",
  "compilerOptions": {
    "types": ["jest", "node"],
    "moduleResolution": "node",
    "baseUrl": "..",
    "paths": {
      "@tests/*": ["tests/*"],
      "@/*": ["src/*"]
    }
  },
  "include": [
    "**/*",
    "../src/**/*"
  ],
  "exclude": [
    "../node_modules",
    "../output"
  ]
}
