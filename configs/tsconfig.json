{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "types": ["node", "jest"],
    "baseUrl": "..",
    "paths": {
      "@tests/*": ["tests/*"],
      "@/*": ["src/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "../output/dist"
  },
  "include": ["../src/**/*", "../tests/**/*"]
}