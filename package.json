{
  "name": "jeopardy-quiz-ts",
  "version": "1.0.0",
  "description": "Interactive Jeopardy Quiz",
  "main": "output/dist/server.js",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"npm run dev:server\" \"npm run dev:client\"",
    "predev:server": "node scripts/kill-port.js 3000",
    "dev:server": "ts-node -P configs/tsconfig.json src/server.ts",
    "dev:client": "wait-on tcp:3000 && vite --config configs/vite.config.ts",
    "stop:server": "node scripts/kill-port.js 3000",
    "validate:html": "node scripts/validate-html-attributes.js",
    "validate": "npm run validate:html",
    "build": "npm run validate:html && vite build --config configs/vite.config.ts && tsc -p configs/tsconfig.build.json",
    "start": "node output/dist/server.js",
    "test": "jest --config configs/jest.config.js",
    "test:watch": "jest --config configs/jest.config.js --watch",
    "test:coverage": "jest --config configs/jest.config.js --coverage",
    "test:unit": "jest --config configs/jest.config.js tests/unit",
    "test:integration": "jest --config configs/jest.config.js tests/integration",
    "test:e2e": "playwright test --config configs/playwright.config.ts",
    "test:e2e:visual": "set PW_VISUAL=1&& playwright test --config configs/playwright.config.ts",
    "test:e2e:all-browsers": "set E2E_ALL_BROWSERS=1&& playwright test --config configs/playwright.config.ts",
    "test:e2e:ui": "playwright test --config configs/playwright.config.ts --ui",
    "test:e2e:report": "npx playwright show-report output/playwright-report",
    "test:all": "npm run test && npm run test:e2e"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "express": "^4.18.2",
    "leaflet": "^1.9.4",
    "mongoose": "^7.0.0",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/adm-zip": "^0.5.7",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.3",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.4.0",
    "@types/qrcode": "^1.5.5",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^7.2.0",
    "concurrently": "^8.2.2",
    "jest": "^30.3.0",
    "jest-mock-extended": "^4.0.0",
    "mongodb-memory-server": "^11.0.1",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6",
    "vite": "^4.4.0",
    "wait-on": "^9.0.4"
  }
}
